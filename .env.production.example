# bchat Production Environment
# Copy to .env and fill in real values:  cp .env.production.example .env

# ---- Database ----
# Password for the PostgreSQL container (used internally by docker-compose)
DB_PASSWORD=change_me_to_a_strong_random_password

# ---- JWT ----
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ---- Telegram Bot (optional — bot disabled if not set) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ---- CORS ----
# Your domain, e.g. https://bchat.example.com
CORS_ORIGIN=https://your-domain.com

# ---- SSL / Domain (used by deploy scripts, not docker-compose) ----
DOMAIN=your-domain.com
EMAIL=your-email@example.com
